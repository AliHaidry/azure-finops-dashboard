# ─────────────────────────────────────────────────────────────────────────────
# azure-finops-dashboard · collector/.env.example
# Copy to .env and fill in your values.
# NEVER commit .env — it is in .gitignore
# ─────────────────────────────────────────────────────────────────────────────

# Azure — comma-separated subscription IDs to collect from
SUBSCRIPTION_IDS=sub1,sub2,sub3

# PostgreSQL — get this from: terraform output pg_connection_string
DATABASE_URL=postgresql://finops_admin:PASSWORD@finops-pg-dev.postgres.database.azure.com:5432/finops_db?sslmode=require

# Collection settings
CURRENCY=USD
DRY_RUN=false

# Prometheus metrics port
PROMETHEUS_PORT=8000

# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
